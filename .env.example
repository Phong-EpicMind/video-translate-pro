# Optional: export these in your shell instead of running `translatedub config set-key`.
# Environment variables take priority over ~/.translatedub/config.json.

# Gemini API key (from https://aistudio.google.com/)
TRANSLATEDUB_GEMINI_KEY=
# Legacy name, also honoured:
GEMINI_API_KEY=

# Google Cloud TTS (optional). Either paste the service-account JSON inline...
TRANSLATEDUB_GOOGLE_CLOUD_CREDENTIALS=
# ...or point to a service-account JSON file:
GOOGLE_APPLICATION_CREDENTIALS=
